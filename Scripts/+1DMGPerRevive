local Xeno = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/itay299/RobloxScripts/main/Scripts/!MyLibrary"
))()

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local reaperRunning = false
local combatRunning = false

-- Auto Reaper (1s)
local function startAutoReaper()
    if reaperRunning then return end
    reaperRunning = true

    task.spawn(function()
        local remote = ReplicatedStorage
            :WaitForChild("rbxts_include")
            :WaitForChild("node_modules")
            :WaitForChild("@rbxts")
            :WaitForChild("remo")
            :WaitForChild("src")
            :WaitForChild("container")
            :WaitForChild("staticReaperReq")

        while reaperRunning do
            pcall(function()
                remote:FireServer()
            end)

            task.wait(1)
        end
    end)
end

local function stopAutoReaper()
    reaperRunning = false
end

-- Better Auto Combat (30.1s)
local function startAutoCombat()
    if combatRunning then return end
    combatRunning = true

    task.spawn(function()
        local remote = ReplicatedStorage
            :WaitForChild("rbxts_include")
            :WaitForChild("node_modules")
            :WaitForChild("@rbxts")
            :WaitForChild("remo")
            :WaitForChild("src")
            :WaitForChild("container")
            :WaitForChild("startTimeLimitChallengeReq")

        while combatRunning do
            pcall(function()
                remote:FireServer(1, 0)
            end)

            task.wait(30.1)
        end
    end)
end

local function stopAutoCombat()
    combatRunning = false
end

-- UI
local UI = Xeno:Create("Plus 1 DMG Per Revive", "Plus 1 DMG Per Revive")

UI:Toggle("Auto Reaper (1s)", false, function(state)
    if state then
        startAutoReaper()
    else
        stopAutoReaper()
    end
end, "AutoReaperToggle")

UI:Toggle("Better Auto Combat (30.1s)", false, function(state)
    if state then
        startAutoCombat()
    else
        stopAutoCombat()
    end
end, "AutoCombatToggle")
