local Xeno = loadstring(game:HttpGet("https://raw.githubusercontent.com/itay299/RobloxScripts/main/Scripts/!MyLibrary"))()
local UI = Xeno:Create("Ban or Get Banned 🔨", game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name)

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- vars
local autoBuy = false
local autoFarm = false
local autoBan = false
local autoChest = false

local bans = {
	"Ban5Min",
	"Ban15Min",
	"Ban30Min",
	"Ban1Hour",
	"Ban1Day",
	"Ban30Days",
	"Ban365Days"
}

-- toggles
UI:Toggle("Auto Buy Bans", false, function(v)
	autoBuy = v
end)

UI:Toggle("Auto Farm Money", false, function(v)
	autoFarm = v
end)

UI:Toggle("Auto Ban Random Player", false, function(v)
	autoBan = v
end)

UI:Toggle("Auto Open Chests", false, function(v)
	autoChest = v
end)

-- auto buy loop
task.spawn(function()
	while true do
		if autoBuy then
			for _, ban in ipairs(bans) do
				ReplicatedStorage:WaitForChild("ShopBuyBan"):FireServer(ban)
				task.wait(0.3)
			end
		end
		task.wait(0.2)
	end
end)

-- auto farm loop
task.spawn(function()
	while true do
		if autoFarm then
			local char = player.Character
			if char and char:FindFirstChild("HumanoidRootPart") then
				char.HumanoidRootPart.CFrame = CFrame.new(-1.5, 2066, -101)
			end
		end
		task.wait(1)
	end
end)

-- auto ban loop (every 60s, random player, Ban5Min)
task.spawn(function()
	while true do
		if autoBan then
			local plrs = Players:GetPlayers()
			if #plrs > 1 then
				local target
				repeat
					target = plrs[math.random(1, #plrs)]
				until target ~= player

				local args = {
					target.Name,
					"Ban5Min"
				}
				ReplicatedStorage:WaitForChild("BanRequest"):FireServer(unpack(args))
			end
		end
		task.wait(60)
	end
end)

-- auto chest loop (every 1s, all chests)
task.spawn(function()
	while true do
		if autoChest then
			local chests = {
				"IronChest",
				"BronzeChest",
				"EmeraldChest",
				"DiamondChest",
				"GoldChest"
			}

			for _, chestName in ipairs(chests) do
				local chest = workspace:WaitForChild("ActiveChests"):FindFirstChild(chestName)
				if chest then
					local args = { chest }
					ReplicatedStorage:WaitForChild("Chest_BuyWithMoney"):FireServer(unpack(args))
				end
			end
		end
		task.wait(1)
	end
end)
