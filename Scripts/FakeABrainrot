-- Xeno library
local Xeno = loadstring(game:HttpGet("https://raw.githubusercontent.com/itay299/RobloxScripts/main/Scripts/!MyLibrary"))()
local UI = Xeno:Create("Fake a Brainrot", "FakeBrainrot")

local Players = game:GetService("Players")
local ProximityPromptService = game:GetService("ProximityPromptService")

local player = Players.LocalPlayer

-- =========================
-- SETTINGS
-- =========================
local detectEnabled = false
local autoStealEnabled = false

local basePosition = nil
local activeStealPrompt = nil

local fakeGui = nil
local activeFakePrompt = nil

-- GOOD BRAINROTS
local goods = {
	["Strawberry Elephant"] = true, -- 300M/s
	["67"] = true, -- 200M/s
	["Dragon Cannelloni"] = true -- 100M/s
}

-- =========================
-- UI
-- =========================
UI:Toggle("Detect Fake Brainrots", false, function(v)
	detectEnabled = v

	if not v then
		activeFakePrompt = nil
		if fakeGui then
			fakeGui:Destroy()
			fakeGui = nil
		end
	end
end, "fake_detect")

UI:Toggle("Auto Steal Good Brainrots", false, function(v)
	autoStealEnabled = v
end, "auto_steal")

UI:Button("Set Base", function()
	local char = player.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")

	if root then
		basePosition = root.CFrame
	end
end)

-- =========================
-- TELEPORT HOME
-- =========================
UI:Button("Teleport Home", function()
	local args = {
		"home"
	}

	game:GetService("ReplicatedStorage")
		:WaitForChild("Events")
		:WaitForChild("TopNavTeleport")
		:FireServer(unpack(args))
end)

-- =========================
-- BRAINROT SYSTEM
-- =========================
local brainrotInput = ""

local function formatBrainrot(str)
	str = tostring(str):lower()

	return (str:gsub("(%a)([%w']*)", function(first, rest)
		return first:upper() .. rest
	end))
end

UI:Textbox("Brainrot Name", function(text)
	brainrotInput = text
end, "brainrot_input")

UI:Button("Become Brainrot", function()
	if brainrotInput == "" then return end

	local formatted = formatBrainrot(brainrotInput)

	local args = {
		formatted
	}

	game:GetService("ReplicatedStorage")
		:WaitForChild("Events")
		:WaitForChild("FakeSystem_StartFake")
		:FireServer(unpack(args))
end)

-- =========================
-- FAKE GUI
-- =========================
local function showGui()
	if fakeGui then return end

	fakeGui = Instance.new("ScreenGui")
	fakeGui.ResetOnSpawn = false
	fakeGui.Parent = player:WaitForChild("PlayerGui")

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 350, 0, 60)
	label.Position = UDim2.new(0.5, -175, 0.15, 0)
	label.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	label.BorderSizePixel = 0
	label.TextColor3 = Color3.fromRGB(255, 60, 60)
	label.TextScaled = true
	label.Font = Enum.Font.GothamBold
	label.Text = "Brainrot is Fake"
	label.Parent = fakeGui
end

local function hideGui()
	if fakeGui then
		fakeGui:Destroy()
		fakeGui = nil
	end
end

-- =========================
-- DETECTION (visibility based)
-- =========================
ProximityPromptService.PromptShown:Connect(function(prompt)
	if not detectEnabled then return end
	if not prompt or not prompt:IsA("ProximityPrompt") then return end

	if prompt.HoldDuration == 0.20000000298023224 then
		activeFakePrompt = prompt
		showGui()
	end
end)

ProximityPromptService.PromptHidden:Connect(function(prompt)
	if prompt == activeFakePrompt then
		activeFakePrompt = nil
		hideGui()
	end
end)

-- =========================
-- AUTO STEAL SYSTEM
-- =========================
task.spawn(function()
	while true do
		if autoStealEnabled then
			local activeItems = workspace:FindFirstChild("ActiveItems")

			local char = player.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")

			if activeItems and root then
				for _, item in ipairs(activeItems:GetChildren()) do
					if goods[item.Name] then
						local mesh = item:FindFirstChild("Mesh")
						local prompt = mesh and mesh:FindFirstChild("PickupPrompt")

						if prompt and prompt:IsA("ProximityPrompt") then
							local original = root.CFrame

							activeStealPrompt = prompt

							-- TP to item
							if mesh:IsA("BasePart") then
								root.CFrame = mesh.CFrame + Vector3.new(0, 3, 0)
							elseif mesh:IsA("Model") then
								local part = mesh:FindFirstChildWhichIsA("BasePart", true)
								if part then
									root.CFrame = part.CFrame + Vector3.new(0, 3, 0)
								end
							end

							task.wait(0.2)

							pcall(function()
								fireproximityprompt(prompt)
							end)

							task.wait(0.2)

							-- return to base
							if basePosition then
								root.CFrame = basePosition
							else
								root.CFrame = original
							end

							activeStealPrompt = nil

							task.wait(1)
						end
					end
				end
			end
		end

		task.wait(1)
	end
end)

-- =========================
-- PROMPT FILTER DURING STEAL
-- =========================
ProximityPromptService.PromptShown:Connect(function(prompt)
	if activeStealPrompt and prompt ~= activeStealPrompt then
		prompt.Enabled = false

		task.delay(1, function()
			if prompt then
				prompt.Enabled = true
			end
		end)
	end
end)
