local Xeno = loadstring(game:HttpGet("https://raw.githubusercontent.com/itay299/RobloxScripts/refs/heads/main/Scripts/!MyLibrary"))()

local UI = Xeno:Create("Dropdown Test", "TestScript")

local player = game.Players.LocalPlayer

local locations = {
    Base = Vector3.new(0, 10, 0),
    Shop = Vector3.new(100, 10, 0),
    Spawn = Vector3.new(-50, 10, 20),
    Tower = Vector3.new(200, 50, 200),
    Cave = Vector3.new(-200, 15, -120),
}

local selected = "Base"
local heightOffset = 0

UI:Dropdown(
    "Teleport To",
    {"Base", "Shop", "Spawn", "Tower", "Cave"},
    "Base",
    function(v)
        selected = v
    end,
    "tp_location"
)

UI:Dropdown(
    "Height Offset",
    {"+5", "+10", "+25"},
    "+5",
    function(v)
        if v == "+5" then
            heightOffset = 5
        elseif v == "+10" then
            heightOffset = 10
        elseif v == "+25" then
            heightOffset = 25
        end
    end,
    "tp_height"
)

UI:Button("Teleport", function()
    local char = player.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = locations[selected]
    if pos then
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, heightOffset, 0))
    end
end)

UI:Button("Teleport + Instant Up", function()
    local char = player.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local pos = locations[selected]
    if pos then
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, heightOffset + 5, 0))
    end
end)

UI:Toggle("Print Selection", false, function(v)
    print("Selected:", selected, "Offset:", heightOffset, v)
end, "debug")
